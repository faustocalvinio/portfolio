---

const { lang = "es" } = Astro.props;
---
      <!-- Información adicional -->
      <div
         class="bg-gray-50 dark:bg-gray-900/50 rounded-xl my-10 p-6 md:p-8 border border-gray-200 dark:border-gray-800"
      >
         <div class="text-center">
            <h4
               class="text-lg font-semibold text-gray-900 dark:text-white mb-3"
            >
               {
                  lang === "es"
                     ? "🌍 Ubicación y Disponibilidad"
                     : "🌍 Location & Availability"
               }
            </h4>
            <p class="text-gray-600 dark:text-gray-400 mb-5 text-sm">
               {
                  lang === "es"
                     ? "📍 Buenos Aires, Argentina • 🏠 Remoto • 🏢 Híbrido • ⏰ Disponible inmediatamente"
                     : "📍 Buenos Aires, Argentina • 🏠 Remote • 🏢 Hybrid • ⏰ Available immediately"
               }
            </p>
            <div class="flex flex-wrap justify-center gap-2">
               <span
                  class="px-3 py-1.5 bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 rounded-full text-xs font-medium border border-emerald-200 dark:border-emerald-800"
               >
                  {lang === "es" ? "Disponible" : "Available"}
               </span>
               <span
                  class="px-3 py-1.5 bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 rounded-full text-xs font-medium border border-blue-200 dark:border-blue-800"
               >
                  Full Stack
               </span>
               <span
                  class="px-3 py-1.5 bg-violet-50 dark:bg-violet-900/30 text-violet-700 dark:text-violet-400 rounded-full text-xs font-medium border border-violet-200 dark:border-violet-800"
               >
                  React/Next.js
               </span>
               <span
                  class="px-3 py-1.5 bg-amber-50 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 rounded-full text-xs font-medium border border-amber-200 dark:border-amber-800"
               >
                  Node.js
               </span>
            </div>
         </div>
      </div>
   </div>