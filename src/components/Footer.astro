---
interface Props {
   TEXTS: string[];
}
const { TEXTS } = Astro.props;
---

<footer class="px-4 md:px-0 mx-auto max-w-[900px] mt-12 pb-6">
   <div class="border-t border-gray-200/50 dark:border-white/5 pt-6">
      <p class="text-center text-sm text-gray-500 dark:text-gray-400">
         {TEXTS[0]}<a
            class="text-blue-600 dark:text-cyan-400 hover:underline transition-colors"
            href="https://porfolio.dev/"
            target="_blank">porfolio.dev</a
         >.{TEXTS[1]}<a
            class="text-blue-600 dark:text-cyan-400 hover:underline transition-colors"
            href="https://github.com/faustocalvinio/fausto-portfolio"
            >{TEXTS[2]}</a
         >.
      </p>
   </div>
</footer>
