---
const { href } = Astro.props;
---

<a
   href={href}
   target="_blank"
   class="inline-flex items-center justify-center gap-2 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 transition-all duration-300 bg-white/60 dark:bg-white/5 border border-gray-200/80 dark:border-white/10 backdrop-blur-sm rounded-xl hover:bg-blue-50 dark:hover:bg-white/10 hover:border-blue-300/60 dark:hover:border-cyan-400/30 hover:text-blue-700 dark:hover:text-cyan-300 hover:shadow-md hover:shadow-blue-500/10 hover:-translate-y-0.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 active:translate-y-0"
>
   <slot />
</a>
