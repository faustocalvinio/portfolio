---
const url = new URL(Astro.request.url);

let navItems = [];

interface Props {
   LANG: string;
}
const { LANG } = Astro.props;

if (LANG === "ES") {
   navItems = [
      {
         title: "Experiencia",
         label: "experiencia",
         url: "#experiencia",
      },
      {
         title: "Proyectos",
         label: "proyectos",
         url: "#proyectos",
      },
      {
         title: "Sobre mí",
         label: "sobre-mi",
         url: "#sobre-mi",
      },
      {
         title: "Contacto",
         label: "contacto",
         url: "#contacto",
      },
   ];
} else if (LANG === "EN") {
   navItems = [
      {
         title: "Experience",
         label: "experience",
         url: "#experience",
      },
      {
         title: "Projects",
         label: "projects",
         url: "#projects",
      },
      {
         title: "About me",
         label: "about-me",
         url: "#about-me",
      },
      {
         title: "Contact",
         label: "contact",
         url: "#contact",
      },
   ];
}
---

<nav
   class="mt-7 md:mt-2 absolute right-3 md:fixed mx-auto z-30 md:w-full md:flex"
>
   <ul
      class="flex gap-4 w-fit mx-auto border border-gray-300/60 dark:border-white/10 bg-white/60 dark:bg-slate-900/50 backdrop-blur-xl px-5 text-lg py-2.5 rounded-2xl items-center shadow-lg shadow-black/5 dark:shadow-black/20"
   >
      {
         navItems.map((link) => (
            <li class="max-sm:hidden">
               <a
                  class="relative block px-1 transition  hover:text-cyan-500 dark:hover:text-cyan-700 "
                  aria-label={link.label}
                  href={link.url}
               >
                  {link.title}
               </a>
            </li>
         ))
      }


       {
         LANG === "ES" ? (
            <li class="items-center md:flex">
               <a
                  class="relative block px-1 transition hover:text-cyan-500 dark:hover:text-cyan-700"
                  aria-label="English"
                  href={ "/en"}
               >
                  EN
               </a>
            </li>
         ) : (
            <li class="items-center md:flex">
               <a
                  class="relative block px-1 transition hover:text-cyan-500 dark:hover:text-cyan-700"
                  aria-label="Español"
                  href={"/"}
               >
                  ES
               </a>
            </li>
         )
       }
   </ul>
</nav>
<style>
   a {
      position: relative;
      transition: color 0.3s ease;
   }
   a:hover {
      @apply hover:text-sky-500 dark:hover:text-cyan-400;
   }
   a::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 50%;
      width: 0;
      height: 2px;
      background: linear-gradient(90deg, #0ea5e9, #6366f1);
      transition: width 0.3s ease, left 0.3s ease;
      border-radius: 1px;
   }
   a:hover::after {
      width: 100%;
      left: 0;
   }
   ul {
      animation: nav-shadown 1s linear both;
      animation-timeline: scroll();
      animation-range: 0 100px;
   }

   @keyframes nav-shadown {
      to {
         background-color: rgba(255, 255, 255, 0.8);
         box-shadow:
            0 8px 32px -4px rgba(0, 0, 0, 0.08),
            0 4px 8px -2px rgba(0, 0, 0, 0.04);
         border: 1px solid rgba(255, 255, 255, 0.5);
         backdrop-filter: blur(16px);
      }
   }

   .dark ul {
      animation: nav-shadown-dark 1s linear both;
      animation-timeline: scroll();
      animation-range: 0 100px;
   }

   @keyframes nav-shadown-dark {
      to {
         background-color: rgba(15, 23, 42, 0.85);
         box-shadow:
            0 8px 32px -4px rgba(0, 0, 0, 0.3),
            0 4px 8px -2px rgba(0, 0, 0, 0.2);
         border: 1px solid rgba(255, 255, 255, 0.06);
         backdrop-filter: blur(16px);
      }
   }
</style>
