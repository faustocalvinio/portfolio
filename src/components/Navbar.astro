---
const url = new URL(Astro.request.url);

let navItems = [];

interface Props {
   LANG: string;
}
const { LANG } = Astro.props;

if (LANG === "ES") {
   navItems = [
      {
         title: "Experiencia",
         label: "experiencia",
         url: "#experiencia",
      },
      {
         title: "Proyectos",
         label: "proyectos",
         url: "#proyectos",
      },
      {
         title: "Sobre mí",
         label: "sobre-mi",
         url: "#sobre-mi",
      },
      {
         title: "Contacto",
         label: "contacto",
         url: "#contact",
      },
   ];
} else if (LANG === "EN") {
   navItems = [
      {
         title: "Experience",
         label: "experience",
         url: "#experience",
      },
      {
         title: "Projects",
         label: "projects",
         url: "#projects",
      },
      {
         title: "About me",
         label: "about-me",
         url: "#about-me",
      },
      {
         title: "Contact",
         label: "contact",
         url: "#contact",
      },
   ];
}
---

<nav
   class="fixed top-0 left-0 right-0 z-30 flex justify-center pt-4 px-4"
>
   <ul
      class="flex gap-1 md:gap-2 w-fit bg-white/80 dark:bg-gray-900/80 backdrop-blur-md px-2 md:px-4 py-2 rounded-full border border-gray-200/60 dark:border-gray-700/60 shadow-sm items-center text-sm md:text-base"
   >
      {
         navItems.map((link) => (
            <li class="max-sm:hidden">
               <a
                  class="relative block px-3 py-1 rounded-full transition-colors duration-200 text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800"
                  aria-label={link.label}
                  href={link.url}
               >
                  {link.title}
               </a>
            </li>
         ))
      }

       {
         LANG === "ES" ? (
            <li class="items-center md:flex">
               <a
                  class="block px-3 py-1 rounded-full transition-colors duration-200 text-gray-500 dark:text-gray-500 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800 font-medium text-sm"
                  aria-label="English"
                  href={ "/en"}
               >
                  EN
               </a>
            </li>
         ) : (
            <li class="items-center md:flex">
               <a
                  class="block px-3 py-1 rounded-full transition-colors duration-200 text-gray-500 dark:text-gray-500 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800 font-medium text-sm"
                  aria-label="Español"
                  href={"/"}
               >
                  ES
               </a>
            </li>
         )
       }
   </ul>
</nav>
