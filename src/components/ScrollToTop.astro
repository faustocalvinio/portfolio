<button
   id="scrollToTopBtn"
   style="transform: translateY(20px);transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1), transform 0.3s cubic-bezier(0.16, 1, 0.3, 1)"
   class="block fixed bottom-6 right-6 p-2 cursor-pointer opacity-0 border-none rounded-xl bg-white/80 dark:bg-slate-800/80 text-gray-700 dark:text-gray-200 backdrop-blur-md shadow-lg shadow-black/5 dark:shadow-black/30 border border-gray-200/50 dark:border-white/10 hover:bg-blue-50 dark:hover:bg-slate-700/80 hover:-translate-y-0.5 transition-all duration-300 z-40"
>
   <svg
      xmlns="http://www.w3.org/2000/svg"
      width="35"
      height="35"
      viewBox="0 0 24 24"
      ><path
         fill="currentColor "
         d="m11 7.825l-4.9 4.9q-.3.3-.7.288t-.7-.313q-.275-.3-.288-.7t.288-.7l6.6-6.6q.15-.15.325-.212T12 4.425t.375.063t.325.212l6.6 6.6q.275.275.275.688t-.275.712q-.3.3-.712.3t-.713-.3L13 7.825V19q0 .425-.288.713T12 20t-.712-.288T11 19z"
      ></path></svg
   >
</button>

<script>
   function initScrollToTop() {
      const scrollToTopBtn = document.getElementById("scrollToTopBtn");
      if (!scrollToTopBtn) return;

      // Remover listeners existentes si los hay
      scrollToTopBtn.replaceWith(scrollToTopBtn.cloneNode(true));
      const newScrollToTopBtn = document.getElementById("scrollToTopBtn");

      // Función para manejar el scroll
      function handleScroll() {
         if (window.scrollY > 200) {
            newScrollToTopBtn.style.opacity = "1";
            newScrollToTopBtn.style.transform = "translateY(0)";
         } else {
            newScrollToTopBtn.style.opacity = "0";
            newScrollToTopBtn.style.transform = "translateY(20px)";
         }
      }

      // Función para scroll to top
      function scrollToTop() {
         window.scrollTo({
            top: 0,
            behavior: "smooth",
         });
      }

      // Agregar event listeners
      window.addEventListener("scroll", handleScroll);
      newScrollToTopBtn.addEventListener("click", scrollToTop);

      // Verificar estado inicial
      handleScroll();
   }

   // Inicializar al cargar
   document.addEventListener("DOMContentLoaded", initScrollToTop);

   // Reinicializar después de view transitions
   document.addEventListener("astro:after-swap", initScrollToTop);
   document.addEventListener("astro:page-load", initScrollToTop);
</script>
