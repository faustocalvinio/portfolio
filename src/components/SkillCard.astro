---
const { name, color, brandColor } = Astro.props;
const customProperties = { "--color-brand": brandColor };
---

<span class={`card`} style={customProperties}>
   <div class={`wrapper`}>
      <div class={`iconWrapper text-[${brandColor}] transition-all`}>
         <slot name="icon" />
      </div>
      <span class={`skillName`}>{name}</span>
   </div>
</span>

<style>
   .card {
      --line-offset: 1px;
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      aspect-ratio: 1 / 1;
      background-color: var(--background-color);
      border-radius: 12px;
      overflow: hidden;
      user-select: none;
      outline: none;
      transition: transform 200ms ease, box-shadow 200ms ease;
   }

   .card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 25px -5px rgba(0, 0, 0, 0.1);
      user-select: none;
      outline: none;
   }

   .card:active {
      transform: translateY(0);
      user-select: none;
      outline: none;
   }

   .card:focus {
      outline: none;
      -webkit-tap-highlight-color: transparent;
   }

   .wrapper {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
   }

   .iconWrapper {
      transition:
         color 200ms ease,
         transform 200ms ease;
      user-select: none;
      outline: none;
   }

   .card:hover .iconWrapper {
      color: var(--color-brand);
      transform: scale(1.1);
      user-select: none;
      outline: none;
   }

   .skillName {
      font-size: 13px;
      font-weight: 500;
      color: var(--color-text-primary);
      opacity: 0.7;
      transition: opacity 200ms ease;
      text-align: center;
      user-select: none;
      outline: none;
   }

   .card:hover .skillName {
      opacity: 1;
   }

   .card:focus-visible,
   .iconWrapper:focus-visible,
   .skillName:focus-visible {
      outline: none;
      box-shadow: none;
      -webkit-tap-highlight-color: transparent;
   }
</style>
