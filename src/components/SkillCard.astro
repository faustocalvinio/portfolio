---
const { name, color, brandColor } = Astro.props;
const customProperties = { "--color-brand": brandColor };
---

<span class={`card`} style={customProperties}>
   <div class={`wrapper`}>
      <div class={`iconWrapper text-[${brandColor}] transition-all`}>
         <slot name="icon" />
      </div>
      <span class={`skillName`}>{name}</span>
   </div>
</span>

<style>
   .card {
      --line-offset: 1px;
      position: relative;
      display: grid;
      justify-items: center;
      align-content: center;
      aspect-ratio: 1 / 1;
      background: rgba(255, 255, 255, 0.5);
      border: 1px solid rgba(255, 255, 255, 0.3);
      border-radius: 16px;
      overflow: hidden;
      user-select: none;
      outline: none;
      transition:
         transform 250ms cubic-bezier(0.16, 1, 0.3, 1),
         box-shadow 250ms ease;
   }

   :global(.dark) .card {
      background: rgba(15, 23, 42, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.06);
   }

   .card:hover {
      transform: translateY(-6px);
      box-shadow: 0 12px 24px -4px rgba(0, 0, 0, 0.08);
      user-select: none;
      outline: none;
   }

   :global(.dark) .card:hover {
      box-shadow: 0 12px 24px -4px rgba(0, 0, 0, 0.3);
   }

   .card::after {
      content: "";
      position: absolute;
      background-color: var(--color-stroke);
      user-select: none;
      outline: none;
   }

   .card::before {
      content: "";
      outline: none;
      user-select: none;
   }

   .card:active {
      transform: translateY(0);
      user-select: none;
      outline: none;
   }

   .card:focus {
      outline: none;
      -webkit-tap-highlight-color: transparent;
   }

   .iconWrapper {
      transition:
         color var(--theme-transition-duration),
         transform var(--theme-transition-duration);
      user-select: none;
      outline: none;
   }

   .card:hover .iconWrapper,
   .display-mobile .iconWrapper {
      color: var(--color-brand);
      transform: translateY(-8px);
      user-select: none;
      outline: none;
   }

   .skillName {
      font-size: 16px;
      font-weight: 500;
      color: var(--color-text-primary);
      position: absolute;
      bottom: 12px;
      left: 50%;
      transform: translateX(-50%) translateY(10px);
      opacity: 0;
      transition:
         opacity 150ms,
         transform 150ms;
      user-select: none;
      outline: none;
   }

   @media (hover: hover) {
      .card:hover .skillName {
         opacity: 1;
         transform: translateX(-50%) translateY(0);
         user-select: none;
         outline: none;
      }
   }

   .card:focus-visible,
   .iconWrapper:focus-visible,
   .skillName:focus-visible {
      outline: none;
      box-shadow: none;
      -webkit-tap-highlight-color: transparent;
   }
   .display-mobile .skillName {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
      user-select: none;
      outline: none;
   }
</style>
<script>
   if (window.innerWidth < 767) {
      const cards = document.querySelectorAll(".card");
      cards.forEach((card) => {
         card.classList.add("display-mobile");
      });
   }
</script>
