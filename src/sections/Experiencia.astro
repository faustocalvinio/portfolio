---
import SectionContainer from "../components/SectionContainer.astro";
import SectionTitle from "../components/SectionTitle.astro";
import ExpLaboralIcon from "../components/icons/ExpLaboralIcon.astro";
interface Props {
   TEXTS: string[];
}
const { TEXTS } = Astro.props;
---

<SectionContainer aditionalClass="flex flex-col" id=`${TEXTS[0].toLowerCase()}`>
   <div class="reveal flex gap-3 items-center">
      <ExpLaboralIcon />
      <SectionTitle title={TEXTS[0]} />
   </div>
   <ol
      class="mt-8 relative border-s-2 border-blue-200/50 dark:border-cyan-800/30 ml-3"
   >
      <li class="reveal reveal-delay-1 mb-12 ms-8">
         <div
            class="absolute w-4 h-4 bg-gradient-to-br from-blue-400 to-indigo-500 rounded-full -start-[9px] ring-4 ring-white dark:ring-slate-950 shadow-lg shadow-blue-500/20"
         >
         </div>
         <div class="glass rounded-xl p-5 glow-blue">
            <time
               class="mb-1.5 block font-medium text-sm text-blue-600 dark:text-cyan-400"
               >{TEXTS[1]}</time
            >
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
               {TEXTS[2]}
            </h3>
            <p class="mb-4 text-gray-600 dark:text-gray-300 leading-relaxed">
               {TEXTS[3]}
            </p>

            <a
               href={`/${TEXTS[8]}`}
               class="inline-flex items-center justify-center gap-2 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 transition-all duration-300 bg-white/60 dark:bg-white/5 border border-gray-200/80 dark:border-white/10 rounded-xl hover:bg-blue-50 dark:hover:bg-white/10 hover:border-blue-300/60 dark:hover:border-cyan-400/30 hover:shadow-md hover:-translate-y-0.5"
            >
               {TEXTS[7]}
            </a>
         </div>
      </li>
      <li class="reveal reveal-delay-2 ms-8">
         <div
            class="absolute w-4 h-4 bg-gradient-to-br from-blue-400 to-indigo-500 rounded-full -start-[9px] ring-4 ring-white dark:ring-slate-950 shadow-lg shadow-blue-500/20"
         >
         </div>
         <div class="glass rounded-xl p-5 glow-blue">
            <time
               class="mb-1.5 block font-medium text-sm text-blue-600 dark:text-cyan-400"
               >{TEXTS[4]}</time
            >
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
               {TEXTS[5]}
            </h3>
            <p class="mb-4 text-gray-600 dark:text-gray-300 leading-relaxed">
               {TEXTS[6]}
            </p>
            <a
               href={`/${TEXTS[10]}`}
               class="inline-flex items-center justify-center gap-2 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 transition-all duration-300 bg-white/60 dark:bg-white/5 border border-gray-200/80 dark:border-white/10 rounded-xl hover:bg-blue-50 dark:hover:bg-white/10 hover:border-blue-300/60 dark:hover:border-cyan-400/30 hover:shadow-md hover:-translate-y-0.5"
            >
               {TEXTS[9]}
            </a>
         </div>
      </li>
   </ol>
</SectionContainer>
