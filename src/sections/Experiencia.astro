---
import SectionContainer from "../components/SectionContainer.astro";
import SectionTitle from "../components/SectionTitle.astro";
import ExpLaboralIcon from "../components/icons/ExpLaboralIcon.astro";
interface Props {
   TEXTS: string[];
}
const { TEXTS } = Astro.props;
---

<SectionContainer aditionalClass="flex flex-col" id=`${TEXTS[0].toLowerCase()}`>
   <div class="flex gap-3 items-center mb-8">
      <ExpLaboralIcon />
      <SectionTitle title={TEXTS[0]} />
   </div>
   <ol class="relative border-s-2 border-gray-200 dark:border-gray-700 ml-2">
      <li class="mb-12 ms-6">
         <div
            class="absolute w-3 h-3 bg-blue-500 rounded-full mt-1.5 -start-[7px] ring-4 ring-white dark:ring-slate-950"
         >
         </div>
         <time class="mb-1 text-sm font-medium text-blue-600 dark:text-blue-400"
            >{TEXTS[1]}</time
         >
         <h3 class="text-lg font-semibold text-gray-900 dark:text-white mt-1">
            {TEXTS[2]}
         </h3>
         <p class="mt-2 text-gray-600 dark:text-gray-400 leading-relaxed">
            {TEXTS[3]}
         </p>
         <a
            href={`/${TEXTS[8]}`}
            class="inline-flex items-center justify-center gap-2 mt-4 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700/50 hover:border-gray-300 dark:hover:border-gray-600 transition-all duration-200 hover:shadow-sm"
         >
            {TEXTS[7]}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
         </a>
      </li>
      <li class="ms-6">
         <div
            class="absolute w-3 h-3 bg-blue-500 rounded-full mt-1.5 -start-[7px] ring-4 ring-white dark:ring-slate-950"
         >
         </div>
         <time class="mb-1 text-sm font-medium text-blue-600 dark:text-blue-400"
            >{TEXTS[4]}</time
         >
         <h3 class="text-lg font-semibold text-gray-900 dark:text-white mt-1">
            {TEXTS[5]}
         </h3>
         <p class="mt-2 text-gray-600 dark:text-gray-400 leading-relaxed">
            {TEXTS[6]}
         </p>
         <a
            href={`/${TEXTS[10]}`}
            class="inline-flex items-center justify-center gap-2 mt-4 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700/50 hover:border-gray-300 dark:hover:border-gray-600 transition-all duration-200 hover:shadow-sm"
         >
            {TEXTS[9]}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
         </a>
      </li>
   </ol>
</SectionContainer>
