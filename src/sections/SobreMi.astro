---
import SectionContainer from "../components/SectionContainer.astro";
import SectionTitle from "../components/SectionTitle.astro";
import SobreMiIcon from "../components/icons/SobreMiIcon.astro";
interface Props {
   TEXTS: string[];
}
const { TEXTS } = Astro.props;
---

<SectionContainer aditionalClass="" id={TEXTS[4]}>
   <div class="flex gap-3 items-center mb-8">
      <SobreMiIcon />
      <SectionTitle title={TEXTS[0]} />
   </div>
   <div class="flex w-full">
      <div class="flex flex-col gap-6 md:gap-8 items-center lg:flex-row lg:gap-12">
         <div class="flex gap-5 flex-col text-gray-600 dark:text-gray-400 leading-relaxed">
            <p>
               {TEXTS[1]}
            </p>

            <p>
               {TEXTS[2]}
            </p>

            <p class="text-gray-900 dark:text-gray-200 font-medium">
               {TEXTS[3]}
            </p>
         </div>
         <img
            class="object-cover order-first lg:order-2 w-52 md:w-56 lg:w-64 aspect-square rounded-2xl shadow-lg ring-1 ring-gray-200 dark:ring-gray-700 rotate-2 flex-shrink-0"
            src="/fotos-mias/frente-auditorio-compressed.webp"
            alt="Foto Fausto Perfil"
         />
      </div>
   </div>
</SectionContainer>
