---
import SectionContainer from "../components/SectionContainer.astro";
import SectionTitle from "../components/SectionTitle.astro";
import SobreMiIcon from "../components/icons/SobreMiIcon.astro";
interface Props {
   TEXTS: string[];
}
const { TEXTS } = Astro.props;
---

<SectionContainer aditionalClass="" id={TEXTS[4]}>
   <div class="reveal flex gap-3 items-center">
      <SobreMiIcon />
      <SectionTitle title={TEXTS[0]} />
   </div>
   <div class="flex w-full mt-6">
      <div class="reveal reveal-delay-1 flex flex-col gap-4 md:gap-8 items-center lg:flex-row">
         <div class="flex gap-5 flex-col text-gray-700 dark:text-gray-300 leading-relaxed">
            <p class="reveal reveal-delay-1">
               {TEXTS[1]}
            </p>

            <p class="reveal reveal-delay-2">
               {TEXTS[2]}
            </p>

            <p class="reveal reveal-delay-3">
               {TEXTS[3]}
            </p>
         </div>
         <div class="relative order-1 md:order-2 group">
            <div class="absolute -inset-1 bg-gradient-to-br from-blue-400/30 via-indigo-400/20 to-cyan-400/30 dark:from-blue-500/20 dark:via-indigo-500/10 dark:to-cyan-500/20 rounded-2xl blur-md group-hover:blur-lg transition-all duration-500"></div>
            <img
               class="relative object-cover w-[75%] md:w-64 h-full p-1 bg-white dark:bg-slate-900 rotate-3 lg:w-64 aspect-square rounded-2xl ring-1 ring-gray-200/50 dark:ring-white/10 shadow-xl group-hover:rotate-0 transition-transform duration-500"
               src="/fotos-mias/frente-auditorio-compressed.webp"
               alt="Foto Fausto Perfil"
            />
         </div>
      </div>
   </div>
</SectionContainer>
